# Include backend and frontend build
!backend/
!frontend/build/
!frontend/public/
!frontend/package.json
!frontend/yarn.lock

# Exclude source and dependencies
backend/__pycache__/
backend/*.pyc
backend/venv/
backend/.venv/
backend/.pytest_cache/
backend/.mypy_cache/

frontend/src/
frontend/node_modules/
frontend/.cache/

# Exclude data files
database1_final/
database2_final/
db_export/
*.csv

# Exclude misc
.git/
.gitignore
.emergent/
test_result.md
*.md
!frontend/README.md
