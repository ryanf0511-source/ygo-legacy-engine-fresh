# Include backend and frontend source
!backend/
!frontend/

# Exclude build artifacts and dependencies
backend/__pycache__/
backend/*.pyc
backend/venv/
backend/.venv/
backend/.pytest_cache/
backend/.mypy_cache/

frontend/node_modules/
frontend/.cache/
frontend/build/

# Exclude data files
database1_final/
database2_final/
db_export/
*.csv

# Exclude misc
.git/
.gitignore
.emergent/
test_result.md
*.md
!frontend/README.md
